# ──────────────────────────────────────────────────────────────────
# CONFIGURAÇÃO DO SISTEMA AVC-EXTRACTION
# Copia este ficheiro para .env e preenche os valores:
#   cp .env.example .env
# ──────────────────────────────────────────────────────────────────

# ── Backend LLM ───────────────────────────────────────────────────
# "ollama"   = local, sem internet (recomendado para dados reais)
# "groq"     = API externa Groq, mais rápido (só para testes)
# "litellm"  = gateway remota LiteLLM (ex: Mac Studio do Rui)
LLM_BACKEND=ollama

# Modelo a usar — aceita um modelo ou lista separada por vírgulas para correr todos seguidos
# ⚠️  Os nomes exactos para LiteLLM dependem da gateway do Rui — confirmar antes de correr
#
# ── Modelo único (para testes rápidos) ────────────────────────────
#ACTIVE_MODEL=llama3.1:8b
#
# ── Todos os 19 modelos (para avaliação completa via LiteLLM) ─────
ACTIVE_MODEL=llama3.2:1b,llama3.2:3b,llama3.1:8b,qwen2.5:0.5b,qwen2.5:1.5b,qwen2.5:3b,qwen2.5:7b,qwen2:7b,gemma3:1b,gemma3:4b,gemma2:9b,phi3.5-mini,phi3-mini,phi4-mini,mistral-nemo,mistral:7b,deepseek-r1:1.5b,deepseek-r1:7b,deepseek-r1:8b
#
# ── Referência de nomes por família ───────────────────────────────
# Llama:      llama3.2:1b | llama3.2:3b | llama3.1:8b
# Qwen:       qwen2.5:0.5b | qwen2.5:1.5b | qwen2.5:3b | qwen2.5:7b | qwen2:7b
# Gemma:      gemma3:1b | gemma3:4b | gemma2:9b
# Phi:        phi3.5-mini | phi3-mini | phi4-mini
# Mistral:    mistral-nemo | mistral:7b
# DeepSeek:   deepseek-r1:1.5b | deepseek-r1:7b | deepseek-r1:8b

# URL do Ollama (não alterar se usares docker-compose)
OLLAMA_BASE_URL=http://localhost:11434

# Chave API do Groq (só necessária se LLM_BACKEND=groq)
# Obtém em: https://console.groq.com → API Keys → Create API Key
GROQ_API_KEY=

# ── LiteLLM (gateway remota) ──────────────────────────────────────
# Usar quando LLM_BACKEND=litellm
# URL base do servidor LiteLLM (ex: http://mac-studio.local:4000)
LITELLM_URL=
# Chave API (pode ser qualquer string se o servidor não exigir autenticação)
LITELLM_API_KEY=

# ── Base de Dados PostgreSQL ───────────────────────────────────────
# Não alterar POSTGRES_HOST se usares docker-compose (é o nome do serviço)
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=avc_extraction
POSTGRES_USER=avc_user
POSTGRES_PASSWORD=escolhe_uma_password_segura

# ── Parse (Asklepic) ──────────────────────────────────────────────
# URL base do serviço de extracção configurável (iframe + endpoint /api/analyze)
PARSE_URL=https://parse-fa63c01c67af7d9c.asklepic.com
# Tipo de análise a usar nos pedidos (ex: cirurgia-cardiaca, avc-isquemico)
PARSE_BLUEPRINT=cirurgia-cardiaca
# Pasta com os .txt de use cases para envio em batch
PARSE_USECASES_DIR=/caminho/para/outputs_teste
